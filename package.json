{
  "name": "adhx",
  "version": "1.32.7",
  "description": "Save now. Read never. Find always. A Twitter/X bookmark manager for people who bookmark everything and read nothing.",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "db:reset": "tsx src/lib/db/reset.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "keywords": [
    "twitter",
    "x",
    "bookmarks",
    "archive",
    "markdown",
    "nextjs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@sentry/node": "^10.33.0",
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.45.2",
    "hls.js": "^1.6.15",
    "jose": "^6.1.3",
    "lucide-react": "^0.468.0",
    "next": "^16.2.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.2.0",
    "twitter-api-v2": "^1.17.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.0",
    "autoprefixer": "^10.4.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.1",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vite": "^6.4.2",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "^6.14.0",
      "minimatch@<3.1.3": "^3.1.3",
      "minimatch@9": "^9.0.7",
      "brace-expansion@<2.0.3": "^2.0.3",
      "brace-expansion@^1.0.0": "^1.1.12",
      "flatted@<3.4.2": "^3.4.2",
      "fast-uri@<3.1.2": "^3.1.2",
      "picomatch@<4.0.4": "^4.0.4",
      "rollup@<4.59.0": "^4.59.0",
      "esbuild@<0.25.0": "^0.25.0",
      "postcss@<8.5.10": "^8.5.10"
    }
  }
}
